{
  "expo": {
    "name": "Fatty",
    "slug": "fatty",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "fatty",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Fatty uses the camera to scan product barcodes so you can log packaged foods quickly."
      }
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store"
    ]
  }
}
