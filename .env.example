# =============================================================================
# Slacks — Self-Host Configuration  (FTY-072)
# =============================================================================
# Copy this file to .env before running `docker compose up`:
#
#   cp .env.example .env
#
# Then set SLACKS_AUTH_SECRET to a freshly-generated secret (see the Auth
# section below) — the app will not start in production mode without it.
#
# These are PLACEHOLDER, NON-SECRET values only. The real .env is gitignored;
# only this template is committed. Never put real keys or credentials here.
#
# Self-host scope: HTTP-only local deployment. TLS / HTTPS termination, reverse
# proxy, production hardening, backups, and cloud deployment are out of scope.
# See the README "Self-Hosting" section for the step-by-step bring-up guide.
# =============================================================================


# =============================================================================
# Auth / App Secret  (REQUIRED — must be set before first boot)
# =============================================================================
# HMAC signing key for local-auth bearer tokens (FTY-020).
#
# This MUST be replaced with a strong random secret before running the stack.
# Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# The app refuses to start in production mode (SLACKS_ENVIRONMENT=production)
# while the default placeholder value is still in place. For local self-host
# development mode, any non-empty string works, but use a real secret.
# This value is server-side only; it is never logged or sent to clients.
SLACKS_AUTH_SECRET=dev-insecure-change-me

# Bearer-token lifetime in seconds. Default 604800 = 7 days.
# Shorten if you want sessions to expire sooner.
#SLACKS_AUTH_TOKEN_TTL_SECONDS=604800

# Auth-endpoint rate limiting (FTY-118).
# Defaults are generous — tune to tighten without a code change.
# Login: per-source-IP and per-account (hashed email) limits.
# Register: per-source-IP limit only.
# All limits are fixed-window counters backed by Redis.
#SLACKS_RATE_LIMIT_LOGIN_IP_MAX=10
#SLACKS_RATE_LIMIT_LOGIN_IP_WINDOW=900
#SLACKS_RATE_LIMIT_LOGIN_ACCOUNT_MAX=5
#SLACKS_RATE_LIMIT_LOGIN_ACCOUNT_WINDOW=900
#SLACKS_RATE_LIMIT_REGISTER_IP_MAX=5
#SLACKS_RATE_LIMIT_REGISTER_IP_WINDOW=3600
# Set to true ONLY when the API sits behind exactly one known, trusted reverse
# proxy that writes X-Forwarded-For. The limiter then keys on the rightmost
# (proxy-appended) hop, so a client-spoofed leftmost value cannot mint fresh
# keys. When false (default) X-Forwarded-For is ignored and the real TCP peer
# is used — trusting the header otherwise would nullify per-IP limiting.
#SLACKS_RATE_LIMIT_TRUSTED_PROXY=false


# =============================================================================
# Datastores
# =============================================================================

# --- Postgres ---
# Credentials for the postgres service container.
# These match the SLACKS_DATABASE_URL below.
POSTGRES_USER=slacks
POSTGRES_PASSWORD=slacks
POSTGRES_DB=slacks
# Postgres is NOT published to the host by default (FTY-109): the api, worker,
# and migrate services reach it over the internal compose network by hostname.
# This var is inert unless you add a loopback-only host mapping in
# docker-compose.yml for direct datastore access (e.g. a DB GUI or local psql) —
# see docs/operations/local-dev-stack.md. The container always listens on 5432.
POSTGRES_PORT=5432

# Postgres DSN consumed by the API, worker, and Alembic migrations.
# Under Docker Compose the hostname MUST be "postgres" (the compose service name).
# A bare postgresql:// DSN selects the psycopg (v3) driver.
SLACKS_DATABASE_URL=postgresql://slacks:slacks@postgres:5432/slacks

# --- Redis ---
# Redis is NOT published to the host by default (FTY-109): the api and worker
# services reach it over the internal compose network by hostname. This var is
# inert unless you add a loopback-only host mapping in docker-compose.yml for
# direct access — see docs/operations/local-dev-stack.md. The container always
# listens on 6379.
REDIS_PORT=6379

# Redis DSN consumed by the API and Celery worker (broker + result backend).
# Under Docker Compose the hostname MUST be "redis" (the compose service name).
SLACKS_REDIS_URL=redis://redis:6379/0


# =============================================================================
# API Host Port
# =============================================================================
# Host port published for the API container (container always listens on 8000).
# Change only if 8000 is already in use on your host.
API_PORT=8000


# =============================================================================
# Application
# =============================================================================
SLACKS_ENVIRONMENT=development
SLACKS_LOG_LEVEL=INFO


# =============================================================================
# LLM Provider  (optional — defaults to "fake"; no key required)
# =============================================================================
# Controls the LLM backend used by the estimation pipeline (FTY-041).
# See docs/contracts/llm-provider.md for the full contract.
#
# SLACKS_LLM_PROVIDER options:
#   fake             Built-in stub; no key or network call. Estimation
#                    degrades gracefully to model-prior-with-status.
#                    Safe default — the app starts and serves health without
#                    any LLM config.
#   openai           OpenAI API. Requires SLACKS_LLM_API_KEY + SLACKS_LLM_MODEL.
#   anthropic        Anthropic API. Requires SLACKS_LLM_API_KEY + SLACKS_LLM_MODEL.
#   openai_compatible Any OpenAI-compatible endpoint (local models, proxies,
#                    OpenRouter).
#                    Requires SLACKS_LLM_MODEL and SLACKS_LLM_BASE_URL pointing at
#                    your endpoint. SLACKS_LLM_API_KEY is OPTIONAL — omit it for
#                    keyless local runtimes (Ollama, LM Studio, vLLM); set it
#                    for keyed remote endpoints (OpenRouter, Together, hosted
#                    proxies). The selected model/provider must support
#                    JSON-schema structured outputs.
#   claude_code      Locally installed first-party Claude Code (subscription).
#                    No SLACKS_LLM_API_KEY — authenticates via your own
#                    'claude login' session. SLACKS_LLM_MODEL is optional (the
#                    session/plan picks the model). Runs headless with all tools
#                    disabled; no per-token billing on a Claude monthly plan.
#                    Requires a one-time 'docker compose exec api claude login'
#                    after first boot — see README Self-Hosting and
#                    docs/operations/local-dev-stack.md for the full flow.
#                    The session is stored in the 'claude-config' Docker volume
#                    (never in the image or this file) and survives restarts.
#                    Confirm availability: GET /healthz/sources -> claude_code.
#   codex           Locally installed first-party Codex CLI. Auth is normally
#                    a one-time 'codex login' / 'codex login --device-auth' /
#                    access-token login inside the api container. The session is
#                    stored in the 'codex-config' Docker volume (CODEX_HOME) and
#                    survives restarts. SLACKS_LLM_MODEL is optional. Do NOT set
#                    SLACKS_LLM_BASE_URL for this provider. SLACKS_LLM_API_KEY is
#                    optional; when set, the adapter maps it only to the Codex
#                    child process as CODEX_API_KEY. Confirm availability:
#                    GET /healthz/sources -> codex.
#
# With SLACKS_LLM_PROVIDER=fake the app starts and all health checks pass;
# estimation uses model-prior-with-status (no live LLM calls).
SLACKS_LLM_PROVIDER=fake

# API key for the selected provider.
# Required for openai/anthropic. Optional for openai_compatible — omit for
# keyless local runtimes (Ollama/LM Studio/vLLM); set for keyed remote endpoints
# such as OpenRouter or Together.
# Not required (and unused) for fake or claude_code. Optional for codex; when
# set, Slacks passes it only to the codex child process as CODEX_API_KEY for that
# invocation. Saved Codex login under CODEX_HOME is the default codex auth path.
# Keep secret: read from env only; never logged or exposed to clients.
#SLACKS_LLM_API_KEY=your-provider-api-key-here

# Model identifier for the selected provider.
# Examples: openai → gpt-4o-mini  |  anthropic → claude-3-5-haiku-20241022
#           OpenRouter → deepseek/deepseek-v4-pro (operator-tunable)
# Required for openai/anthropic/openai_compatible. Optional for claude_code and
# codex (the local CLI session/config selects the model); unused for fake.
#SLACKS_LLM_MODEL=

# Base URL override. Required for openai_compatible; optional for OpenAI/
# Anthropic API providers. Not used by codex — leave unset when
# SLACKS_LLM_PROVIDER=codex.
#
# Keyless local runtime examples (no SLACKS_LLM_API_KEY needed):
#   Ollama:    SLACKS_LLM_BASE_URL=http://localhost:11434/v1
#   LM Studio: SLACKS_LLM_BASE_URL=http://localhost:1234/v1
#   vLLM:      SLACKS_LLM_BASE_URL=http://localhost:8000/v1
#
# Remote keyed endpoints (SLACKS_LLM_API_KEY required):
#   OpenRouter: SLACKS_LLM_BASE_URL=https://openrouter.ai/api/v1
#   Together:  SLACKS_LLM_BASE_URL=https://api.together.xyz/v1
#
# OpenRouter is still configured through SLACKS_LLM_PROVIDER=openai_compatible.
# When the base URL is https://openrouter.ai/api/v1, Slacks adds OpenRouter's
# provider.require_parameters=true routing preference on structured-output
# requests so OpenRouter uses only endpoints that honor response_format.
# Choose an OpenRouter model/provider with structured_outputs / response_format
# support; deepseek/deepseek-v4-pro is the intended local dogfooding default, but
# the slug is operator-tunable.
#
# Must be an https URL for remote endpoints.
#SLACKS_LLM_BASE_URL=

# Per-attempt wall-clock timeout in seconds (range 0–600). Default: 30.
#SLACKS_LLM_TIMEOUT_SECONDS=30

# Extra retry attempts after the first on transient failures (range 0–10). Default: 2.
#SLACKS_LLM_MAX_RETRIES=2

# Set true only if the configured model supports vision/image input (FTY-076).
# Must be true before supplying images to structured_completion; fails fast
# otherwise. Defaults to false so existing text-only deployments are unaffected.
# Required for image-capable Codex models before label/image inputs are sent to
# the codex provider.
#SLACKS_LLM_SUPPORTS_VISION=false


# =============================================================================
# Estimator Clarification Policy
# =============================================================================
# Controls when the natural-language estimator asks a follow-up question instead
# of making a visibly rough, editable estimate.
#
# Default: estimate_first. Slacks estimates from recognizable food/exercise
# identities and stated details first, then asks only when genuinely stuck.
# Stricter modes are available for operators who prefer fewer rough estimates:
#   estimate_first  default; rare clarification, rough estimates preferred
#   balanced        calibrated abstention threshold, but never re-asks for a
#                   detail the user already stated
#   strict          allows older-style amount questions for more precision
#
# These settings are not secrets. They do not change privacy, logging,
# redaction, provider validation, hardened fetch, or source-validation rules.
# Invalid values fail at startup rather than silently falling back.
#SLACKS_ESTIMATOR_CLARIFY_MODE=estimate_first

# Optional parse clarify threshold override for balanced/strict modes.
# Leave unset to use the calibrated parse threshold. Range: 0.0–1.0.
#SLACKS_ESTIMATOR_PARSE_CLARIFY_THRESHOLD=0.702

# Minimum cold-pass/model-prior agreement for accepting rough nutrition facts.
# Lower values accept more rough estimates; higher values leave more fields
# unknown or route to an allowed clarification reason. Range: 0.0–1.0.
# Default: 0.6.
#SLACKS_ESTIMATOR_MODEL_PRIOR_CONFIDENCE_FLOOR=0.6

# Maximum deterministic parse-provider schema-shape repair attempts before a
# trusted ParseResult exists. Range: 0–10. Default: 2.
#SLACKS_ESTIMATOR_MAX_PARSE_REPAIR_ATTEMPTS=2


# =============================================================================
# USDA FoodData Central  (optional — free API key from data.gov)
# =============================================================================
# Enables generic-food USDA nutrition lookups (FTY-044).
# Obtain a free key at https://fdc.nal.usda.gov/api-guide
# When omitted the source is disabled; the app starts and degrades to
# model-prior-with-status for inputs that would have used USDA data.
# Keep secret: sent in the X-Api-Key header only; never logged or exposed to clients.
#SLACKS_FDC_API_KEY=your-usda-fdc-api-key-here

# FDC API base URL. Override for self-hosted mirrors or proxies.
# Must be an https URL. Default: https://api.nal.usda.gov/fdc/v1
#SLACKS_FDC_BASE_URL=https://api.nal.usda.gov/fdc/v1

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#SLACKS_FDC_TIMEOUT_SECONDS=10

# Number of FDC search results inspected for an energy-bearing match (range 1–25). Default: 5.
#SLACKS_FDC_MAX_RESULTS=5


# =============================================================================
# Open Food Facts  (optional, open API — no key required; enabled by default)
# =============================================================================
# Enables barcode/packaged-product lookups via the Open Food Facts database (FTY-060).
# OFF is a free, open API that requires no key. Defaults to ENABLED (true).
# Set SLACKS_OFF_ENABLED=false to disable it entirely.
# Only the normalized barcode is sent — never any personal context.
SLACKS_OFF_ENABLED=true

# OFF API base URL override (for self-hosted mirrors/proxies). Must be an https URL.
#SLACKS_OFF_BASE_URL=https://world.openfoodfacts.org

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#SLACKS_OFF_TIMEOUT_SECONDS=10

# Non-secret identifying user-agent sent to OFF per their API etiquette.
#SLACKS_OFF_USER_AGENT=Slacks/1.0 (+https://github.com/epurn/slacks)


# =============================================================================
# Official-Source Web Search  (default: keyless local SearXNG — no API key)
# =============================================================================
# Official-source nutrition web search (FTY-079/164). The default backend is the
# local/self-hosted SearXNG instance run by the compose `searxng` service
# (FTY-165), which needs NO API key — search works out of the box. Only the
# sanitized item name is ever sent — no personal context.
# Providers: searxng (keyless default) | brave (needs a key) | none (explicit off).
#
# These three defaults are set explicitly so the stack points at the compose
# `searxng` service with no extra configuration. Change them only to opt into
# Brave (see below) or to turn search off (provider=none or enabled=false).
SLACKS_SEARCH_ENABLED=true
SLACKS_SEARCH_PROVIDER=searxng

# Search API base URL. Points at the compose `searxng` service by default.
# (Per-provider fallbacks if unset: http://searxng:8080 for searxng,
# https://api.search.brave.com for brave — path appended by the client.) Must be
# https, except SearXNG may use plain http for LOCAL targets only (the `searxng`
# service name, localhost, or a loopback IP) — a public SearXNG URL must be https.
SLACKS_SEARCH_BASE_URL=http://searxng:8080

# Brave opt-in only: select the provider and supply its API key
# (https://brave.com/search/api/). Keep secret: sent in the X-Subscription-Token
# header only; never logged or exposed to clients. SearXNG ignores this key.
#SLACKS_SEARCH_PROVIDER=brave
#SLACKS_SEARCH_API_KEY=your-brave-search-api-key-here

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#SLACKS_SEARCH_TIMEOUT_SECONDS=10

# Maximum candidate results surfaced per query (range 1–20). Default: 5.
#SLACKS_SEARCH_MAX_RESULTS=5


# =============================================================================
# Official-Source Fetch Egress  (optional — fail-closed by default; no secrets)
# =============================================================================
# The hardened official-source page fetcher (FTY-078) retrieves an allowlisted
# public official-source page and returns active-content-stripped inert text for
# extraction. It shares the FTY-044 hardened-fetch SSRF boundary (HTTPS +
# public-IP only, redirects refused, bounded size/timeout/content-type,
# content-free errors). Fail-closed by default: with an empty host allowlist,
# nothing is fetchable. Set the comma-separated host allowlist to enable specific
# official sources. The configured policy is visible at GET /healthz/egress.
# These are non-secret egress limits — no keys here.

# Comma-separated host allowlist. Empty (default) fetches nothing.
#SLACKS_OFFICIAL_FETCH_ALLOWED_HOSTS=www.example-restaurant.com,nutrition.example.com

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#SLACKS_OFFICIAL_FETCH_TIMEOUT_SECONDS=10

# Response-size cap in bytes; larger responses fail closed. Default: 2000000.
#SLACKS_OFFICIAL_FETCH_MAX_BYTES=2000000

# Allowed response content types (comma-separated).
#SLACKS_OFFICIAL_FETCH_ALLOWED_CONTENT_TYPES=text/html,application/xhtml+xml,text/plain


# =============================================================================
# Reference-Source (Searched-Result) Fetch Egress  (optional — on by default)
# =============================================================================
# The searched-result fetcher (FTY-166) retrieves a PUBLIC search-result page
# (a nutrition reference page the search adapter surfaced) for the
# reference_source evidence tier, and returns active-content-stripped inert text
# for extraction. There is deliberately no host allowlist — eligible targets are
# the public result URLs search returned — so the full hardened-fetch posture
# applies to every fetch: HTTPS only, public-IP only (loopback/private/link-local/
# metadata blocked, vetted IP pinned), redirects refused, bounded
# size/timeout/content-type, content-free errors, and raw pages never persisted.
# On by default (like search itself); set enabled=false to turn the tier off.
# The configured policy is visible at GET /healthz/egress. No secrets here.

# Whether searched public result pages may be fetched at all. Default: true.
#SLACKS_REFERENCE_FETCH_ENABLED=true

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#SLACKS_REFERENCE_FETCH_TIMEOUT_SECONDS=10

# Response-size cap in bytes; larger responses fail closed. Default: 2000000.
#SLACKS_REFERENCE_FETCH_MAX_BYTES=2000000

# Allowed response content types (comma-separated).
#SLACKS_REFERENCE_FETCH_ALLOWED_CONTENT_TYPES=text/html,application/xhtml+xml,text/plain
