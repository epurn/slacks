# Docker Compose environment for the local Fatty dev stack (FTY-011).
#
# Copy to `.env` before running `docker compose up`:
#
#     cp .env.example .env
#
# These are PLACEHOLDER, NON-SECRET local-development values only. The real
# `.env` is gitignored — never commit real secrets, provider keys, or
# production credentials. Provider API keys are not part of this stack and are
# added by later stories.

# --- Postgres (local dev credentials; not secrets) ---
POSTGRES_USER=fatty
POSTGRES_PASSWORD=fatty
POSTGRES_DB=fatty
# Host port published for Postgres (container always listens on 5432).
POSTGRES_PORT=5432

# Host port published for Redis (container always listens on 6379).
REDIS_PORT=6379

# Host port published for the API (container always listens on 8000).
API_PORT=8000

# --- Backend application config (FATTY_-prefixed; see backend/app/settings.py) ---
FATTY_ENVIRONMENT=development
FATTY_LOG_LEVEL=INFO
# Service URLs use the compose service names (postgres, redis) as hostnames.
# FATTY_DATABASE_URL is reserved for the later database story (not used yet).
FATTY_DATABASE_URL=postgresql://fatty:fatty@postgres:5432/fatty
FATTY_REDIS_URL=redis://redis:6379/0
