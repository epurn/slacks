# =============================================================================
# Fatty — Self-Host Configuration  (FTY-072)
# =============================================================================
# Copy this file to .env before running `docker compose up`:
#
#   cp .env.example .env
#
# Then set FATTY_AUTH_SECRET to a freshly-generated secret (see the Auth
# section below) — the app will not start in production mode without it.
#
# These are PLACEHOLDER, NON-SECRET values only. The real .env is gitignored;
# only this template is committed. Never put real keys or credentials here.
#
# Self-host scope: HTTP-only local deployment. TLS / HTTPS termination, reverse
# proxy, production hardening, backups, and cloud deployment are out of scope.
# See the README "Self-Hosting" section for the step-by-step bring-up guide.
# =============================================================================


# =============================================================================
# Auth / App Secret  (REQUIRED — must be set before first boot)
# =============================================================================
# HMAC signing key for local-auth bearer tokens (FTY-020).
#
# This MUST be replaced with a strong random secret before running the stack.
# Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#
# The app refuses to start in production mode (FATTY_ENVIRONMENT=production)
# while the default placeholder value is still in place. For local self-host
# development mode, any non-empty string works, but use a real secret.
# This value is server-side only; it is never logged or sent to clients.
FATTY_AUTH_SECRET=dev-insecure-change-me

# Bearer-token lifetime in seconds. Default 604800 = 7 days.
# Shorten if you want sessions to expire sooner.
#FATTY_AUTH_TOKEN_TTL_SECONDS=604800


# =============================================================================
# Datastores
# =============================================================================

# --- Postgres ---
# Credentials for the postgres service container.
# These match the FATTY_DATABASE_URL below.
POSTGRES_USER=fatty
POSTGRES_PASSWORD=fatty
POSTGRES_DB=fatty
# Postgres is NOT published to the host by default (FTY-109): the api, worker,
# and migrate services reach it over the internal compose network by hostname.
# This var is inert unless you add a loopback-only host mapping in
# docker-compose.yml for direct datastore access (e.g. a DB GUI or local psql) —
# see docs/operations/local-dev-stack.md. The container always listens on 5432.
POSTGRES_PORT=5432

# Postgres DSN consumed by the API, worker, and Alembic migrations.
# Under Docker Compose the hostname MUST be "postgres" (the compose service name).
# A bare postgresql:// DSN selects the psycopg (v3) driver.
FATTY_DATABASE_URL=postgresql://fatty:fatty@postgres:5432/fatty

# --- Redis ---
# Redis is NOT published to the host by default (FTY-109): the api and worker
# services reach it over the internal compose network by hostname. This var is
# inert unless you add a loopback-only host mapping in docker-compose.yml for
# direct access — see docs/operations/local-dev-stack.md. The container always
# listens on 6379.
REDIS_PORT=6379

# Redis DSN consumed by the API and Celery worker (broker + result backend).
# Under Docker Compose the hostname MUST be "redis" (the compose service name).
FATTY_REDIS_URL=redis://redis:6379/0


# =============================================================================
# API Host Port
# =============================================================================
# Host port published for the API container (container always listens on 8000).
# Change only if 8000 is already in use on your host.
API_PORT=8000


# =============================================================================
# Application
# =============================================================================
FATTY_ENVIRONMENT=development
FATTY_LOG_LEVEL=INFO


# =============================================================================
# LLM Provider  (optional — defaults to "fake"; no key required)
# =============================================================================
# Controls the LLM backend used by the estimation pipeline (FTY-041).
# See docs/contracts/llm-provider.md for the full contract.
#
# FATTY_LLM_PROVIDER options:
#   fake             Built-in stub; no key or network call. Estimation
#                    degrades gracefully to model-prior-with-status.
#                    Safe default — the app starts and serves health without
#                    any LLM config.
#   openai           OpenAI API. Requires FATTY_LLM_API_KEY + FATTY_LLM_MODEL.
#   anthropic        Anthropic API. Requires FATTY_LLM_API_KEY + FATTY_LLM_MODEL.
#   openai_compatible Any OpenAI-compatible endpoint (local models, proxies).
#                    Requires FATTY_LLM_MODEL and FATTY_LLM_BASE_URL pointing at
#                    your endpoint. FATTY_LLM_API_KEY is OPTIONAL — omit it for
#                    keyless local runtimes (Ollama, LM Studio, vLLM); set it
#                    for keyed remote endpoints (Together, hosted proxies).
#   claude_code      Locally installed first-party Claude Code (subscription).
#                    No FATTY_LLM_API_KEY — authenticates via your own
#                    'claude login' session. FATTY_LLM_MODEL is optional (the
#                    session/plan picks the model). Runs headless with all tools
#                    disabled; no per-token billing on a Claude monthly plan.
#                    Requires a one-time 'docker compose exec api claude login'
#                    after first boot — see README Self-Hosting and
#                    docs/operations/local-dev-stack.md for the full flow.
#                    The session is stored in the 'claude-config' Docker volume
#                    (never in the image or this file) and survives restarts.
#                    Confirm availability: GET /healthz/sources -> claude_code.
#
# With FATTY_LLM_PROVIDER=fake the app starts and all health checks pass;
# estimation uses model-prior-with-status (no live LLM calls).
FATTY_LLM_PROVIDER=fake

# API key for the selected provider.
# Required for openai/anthropic. Optional for openai_compatible — omit for
# keyless local runtimes (Ollama/LM Studio/vLLM); set for keyed remote endpoints.
# Not required (and unused) for fake or claude_code.
# Keep secret: read from env only; never logged or exposed to clients.
#FATTY_LLM_API_KEY=your-provider-api-key-here

# Model identifier for the selected provider.
# Examples: openai → gpt-4o-mini  |  anthropic → claude-3-5-haiku-20241022
# Required for openai/anthropic/openai_compatible. Optional for claude_code
# (the Claude Code session/plan selects the model); unused for fake.
#FATTY_LLM_MODEL=

# Base URL override. Required for openai_compatible; optional for others.
#
# Keyless local runtime examples (no FATTY_LLM_API_KEY needed):
#   Ollama:    FATTY_LLM_BASE_URL=http://localhost:11434/v1
#   LM Studio: FATTY_LLM_BASE_URL=http://localhost:1234/v1
#   vLLM:      FATTY_LLM_BASE_URL=http://localhost:8000/v1
#
# Remote keyed endpoints (FATTY_LLM_API_KEY required):
#   Together:  FATTY_LLM_BASE_URL=https://api.together.xyz/v1
#
# Must be an https URL for remote endpoints.
#FATTY_LLM_BASE_URL=

# Per-attempt wall-clock timeout in seconds (range 0–600). Default: 30.
#FATTY_LLM_TIMEOUT_SECONDS=30

# Extra retry attempts after the first on transient failures (range 0–10). Default: 2.
#FATTY_LLM_MAX_RETRIES=2

# Set true only if the configured model supports vision/image input (FTY-076).
# Must be true before supplying images to structured_completion; fails fast
# otherwise. Defaults to false so existing text-only deployments are unaffected.
#FATTY_LLM_SUPPORTS_VISION=false


# =============================================================================
# USDA FoodData Central  (optional — free API key from data.gov)
# =============================================================================
# Enables generic-food USDA nutrition lookups (FTY-044).
# Obtain a free key at https://fdc.nal.usda.gov/api-guide
# When omitted the source is disabled; the app starts and degrades to
# model-prior-with-status for inputs that would have used USDA data.
# Keep secret: sent in the X-Api-Key header only; never logged or exposed to clients.
#FATTY_FDC_API_KEY=your-usda-fdc-api-key-here

# FDC API base URL. Override for self-hosted mirrors or proxies.
# Must be an https URL. Default: https://api.nal.usda.gov/fdc/v1
#FATTY_FDC_BASE_URL=https://api.nal.usda.gov/fdc/v1

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#FATTY_FDC_TIMEOUT_SECONDS=10

# Number of FDC search results inspected for an energy-bearing match (range 1–25). Default: 5.
#FATTY_FDC_MAX_RESULTS=5


# =============================================================================
# Open Food Facts  (optional, open API — no key required; enabled by default)
# =============================================================================
# Enables barcode/packaged-product lookups via the Open Food Facts database (FTY-060).
# OFF is a free, open API that requires no key. Defaults to ENABLED (true).
# Set FATTY_OFF_ENABLED=false to disable it entirely.
# Only the normalized barcode is sent — never any personal context.
FATTY_OFF_ENABLED=true

# OFF API base URL override (for self-hosted mirrors/proxies). Must be an https URL.
#FATTY_OFF_BASE_URL=https://world.openfoodfacts.org

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#FATTY_OFF_TIMEOUT_SECONDS=10

# Non-secret identifying user-agent sent to OFF per their API etiquette.
#FATTY_OFF_USER_AGENT=Fatty/1.0 (+https://github.com/epurn/fatty)


# =============================================================================
# Official-Source Web Search  (optional — disabled by default; no bundled key)
# =============================================================================
# Enables official-source nutrition web search via Brave Search API (FTY-079).
# Disabled by default: no key is bundled. Without a key the source is
# unavailable regardless of FATTY_SEARCH_ENABLED; the estimator falls through
# to the model-prior path.
# Obtain a Brave Search API key at https://brave.com/search/api/
# Keep secret: sent in the X-Subscription-Token header only; never logged or
# exposed to clients. Only the sanitized item name is sent — no personal context.
#FATTY_SEARCH_ENABLED=false
#FATTY_SEARCH_PROVIDER=brave
#FATTY_SEARCH_API_KEY=your-brave-search-api-key-here

# Brave Search API base URL override. Must be an https URL. The request path
# (/res/v1/web/search) is appended by the client — set only the host base here.
#FATTY_SEARCH_BASE_URL=https://api.search.brave.com

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#FATTY_SEARCH_TIMEOUT_SECONDS=10

# Maximum search results returned per query (range 1–20). Default: 5.
#FATTY_SEARCH_MAX_RESULTS=5


# =============================================================================
# Official-Source Fetch Egress  (optional — fail-closed by default; no secrets)
# =============================================================================
# The hardened official-source page fetcher (FTY-078) retrieves an allowlisted
# public official-source page and returns active-content-stripped inert text for
# extraction. It shares the FTY-044 hardened-fetch SSRF boundary (HTTPS +
# public-IP only, redirects refused, bounded size/timeout/content-type,
# content-free errors). Fail-closed by default: with an empty host allowlist,
# nothing is fetchable. Set the comma-separated host allowlist to enable specific
# official sources. The configured policy is visible at GET /healthz/egress.
# These are non-secret egress limits — no keys here.

# Comma-separated host allowlist. Empty (default) fetches nothing.
#FATTY_OFFICIAL_FETCH_ALLOWED_HOSTS=www.example-restaurant.com,nutrition.example.com

# Per-request wall-clock timeout in seconds (range 0–120). Default: 10.
#FATTY_OFFICIAL_FETCH_TIMEOUT_SECONDS=10

# Response-size cap in bytes; larger responses fail closed. Default: 2000000.
#FATTY_OFFICIAL_FETCH_MAX_BYTES=2000000

# Allowed response content types (comma-separated).
#FATTY_OFFICIAL_FETCH_ALLOWED_CONTENT_TYPES=text/html,application/xhtml+xml,text/plain
